<Window x:Class="MemCommitMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MemCommit Monitor"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F5F7"
        Icon="{StaticResource AppLogoSmall}">

    <Window.Resources>
        <!-- macOS 风格颜色系统 -->
        <SolidColorBrush x:Key="MacOS.Background" Color="#FFF5F5F7"/>
        <SolidColorBrush x:Key="MacOS.Card" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MacOS.Blue" Color="#FF007AFF"/>
        <SolidColorBrush x:Key="MacOS.BlueHover" Color="#FF0051D5"/>
        <SolidColorBrush x:Key="MacOS.Red" Color="#FFFF3B30"/>
        <SolidColorBrush x:Key="MacOS.RedHover" Color="#FFD5291F"/>
        <SolidColorBrush x:Key="MacOS.Orange" Color="#FFFF9500"/>
        <SolidColorBrush x:Key="MacOS.OrangeHover" Color="#FFD57700"/>
        <SolidColorBrush x:Key="MacOS.Green" Color="#FF34C759"/>
        <SolidColorBrush x:Key="MacOS.Gray" Color="#FF8E8E93"/>
        <SolidColorBrush x:Key="MacOS.LightGray" Color="#FFF2F2F7"/>
        <SolidColorBrush x:Key="MacOS.Text" Color="#FF000000"/>
        <SolidColorBrush x:Key="MacOS.TextSecondary" Color="#FF6C6C70"/>
        <SolidColorBrush x:Key="MacOS.Divider" Color="#FFE5E5EA"/>

        <!-- macOS 风格标题样式 -->
        <Style x:Key="MacTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource MacOS.Text}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- macOS 风格副标题样式 -->
        <Style x:Key="MacSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource MacOS.Text}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- macOS 风格正文样式 -->
        <Style x:Key="MacBodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource MacOS.Text}"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <!-- macOS 风格辅助文本样式 -->
        <Style x:Key="MacCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource MacOS.TextSecondary}"/>
        </Style>

        <!-- macOS 风格主按钮 -->
        <Style x:Key="MacPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource MacOS.Blue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.08"
                                                BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource MacOS.BlueHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- macOS 风格复选框 -->
        <Style x:Key="MacCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource MacOS.Text}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- macOS 风格卡片 -->
        <Style x:Key="MacCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource MacOS.Card}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.06"
                                    BlurRadius="12" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- macOS 风格右键菜单 -->
        <Style x:Key="MacContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource MacOS.Divider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.12"
                                                BlurRadius="16" ShadowDepth="4" Direction="270"/>
                            </Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- macOS 风格菜单项 -->
        <Style x:Key="MacMenuItem" TargetType="MenuItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border"
                                Background="Transparent"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFE3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- macOS 风格分隔线 -->
        <Style x:Key="MacSeparator" TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{StaticResource MacOS.Divider}"/>
            <Setter Property="Margin" Value="8,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24" Background="{StaticResource MacOS.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 系统内存状态卡片 -->
        <Border Grid.Row="0"
                Style="{StaticResource MacCard}"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="系统内存" Style="{StaticResource MacTitleStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="已提交内存"
                                 Style="{StaticResource MacCaptionStyle}"
                                 Margin="0,0,0,4"/>
                        <TextBlock x:Name="CommittedMemoryText"
                                 Style="{StaticResource MacBodyStyle}"
                                 FontWeight="Medium"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="物理内存"
                                 Style="{StaticResource MacCaptionStyle}"
                                 Margin="0,0,0,4"/>
                        <TextBlock x:Name="PhysicalMemoryText"
                                 Style="{StaticResource MacBodyStyle}"
                                 FontWeight="Medium"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="LastUpdateText"
                         Style="{StaticResource MacCaptionStyle}"
                         Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- 操作工具栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="RefreshButton"
                        Content="🔄 刷新"
                        Style="{StaticResource MacPrimaryButton}"
                        Click="RefreshButton_Click"/>
                <CheckBox x:Name="HideSystemProcessCheckBox"
                          Content="隐藏系统进程"
                          Style="{StaticResource MacCheckBox}"
                          Margin="16,0,0,0"
                          Checked="FilterChanged"
                          Unchecked="FilterChanged"
                          ToolTip="只显示用户程序"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center">
                <TextBlock x:Name="StatusText"
                          Style="{StaticResource MacBodyStyle}"
                          Foreground="{StaticResource MacOS.Green}"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"/>
                <TextBlock Text="💡 右键点击进程查看操作"
                          Style="{StaticResource MacCaptionStyle}"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 进程列表卡片 -->
        <Border Grid.Row="2"
                Style="{StaticResource MacCard}"
                Padding="0">
            <DataGrid x:Name="ProcessDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="ProcessDataGrid_SelectionChanged"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="Transparent"
                      RowHeight="44"
                      FontSize="13"
                      CanUserResizeRows="False"
                      CanUserReorderColumns="False">

                <!-- macOS 风格行样式 -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource MacOS.Divider}"/>
                        <Style.Triggers>
                            <!-- 系统进程 -->
                            <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                <Setter Property="Background" Value="{StaticResource MacOS.LightGray}"/>
                                <Setter Property="Foreground" Value="{StaticResource MacOS.TextSecondary}"/>
                            </DataTrigger>
                            <!-- 悬停效果 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF0F0F5"/>
                            </Trigger>
                            <!-- 选中效果 -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FFE3F2FD"/>
                                <Setter Property="Foreground" Value="{StaticResource MacOS.Blue}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <!-- macOS 风格右键菜单 -->
                <DataGrid.ContextMenu>
                    <ContextMenu Style="{StaticResource MacContextMenu}">
                        <MenuItem Header="💾 释放工作集"
                                 Style="{StaticResource MacMenuItem}"
                                 Click="ReleaseButton_Click"
                                 ToolTip="释放物理内存（不减少已提交内存）"/>
                        <MenuItem Header="⚠️ 终止进程"
                                 Style="{StaticResource MacMenuItem}"
                                 Click="TerminateButton_Click"
                                 ToolTip="终止进程（真正释放已提交内存）"
                                 Foreground="{StaticResource MacOS.Red}"
                                 FontWeight="Medium"/>
                        <MenuItem Header="🧪 实验性释放"
                                 Style="{StaticResource MacMenuItem}"
                                 Click="ExperimentalReleaseButton_Click"
                                 ToolTip="实验性功能，有崩溃风险"
                                 Foreground="{StaticResource MacOS.Orange}"
                                 FontWeight="Medium"/>
                        <Separator Style="{StaticResource MacSeparator}"/>
                        <MenuItem Header="📋 查看进程详情"
                                 Style="{StaticResource MacMenuItem}"
                                 Click="ViewProcessDetails_Click"/>
                        <MenuItem Header="🔄 刷新列表"
                                 Style="{StaticResource MacMenuItem}"
                                 Click="RefreshButton_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <!-- macOS 风格表头样式 -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource MacOS.TextSecondary}"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="Padding" Value="16,12"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource MacOS.Divider}"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- macOS 风格单元格样式 -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                           Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource MacOS.Blue}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="PID"
                                       Binding="{Binding ProcessId}"
                                       Width="90"/>
                    <DataGridTextColumn Header="进程名称"
                                       Binding="{Binding ProcessName}"
                                       Width="180"/>
                    <DataGridTextColumn Header="类型"
                                       Binding="{Binding ProcessType}"
                                       Width="110"/>
                    <DataGridTextColumn Header="已提交内存"
                                       Binding="{Binding FormattedPrivate}"
                                       Width="130"/>
                    <DataGridTextColumn Header="工作集"
                                       Binding="{Binding FormattedWorkingSet}"
                                       Width="130"/>
                    <DataGridTextColumn Header="状态"
                                       Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="正常"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                        <Setter Property="Text" Value="🔒 受保护"/>
                                        <Setter Property="Foreground" Value="{StaticResource MacOS.Red}"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SuggestClose}" Value="True">
                                        <Setter Property="Text" Value="💡 建议关闭"/>
                                        <Setter Property="Foreground" Value="{StaticResource MacOS.Orange}"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>



