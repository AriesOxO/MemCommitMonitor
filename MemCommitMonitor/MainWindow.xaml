<Window x:Class="MemCommitMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MemCommit Monitor - Windows 已提交内存管理器"
        Height="650" Width="1000"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- 标题样式 -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- 数据文本样式 -->
        <Style x:Key="DataTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 系统内存状态面板 -->
        <Border Grid.Row="0"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="5"
                Padding="15"
                Margin="0,0,0,15"
                Background="#F9F9F9">
            <StackPanel>
                <TextBlock Text="系统内存状态" Style="{StaticResource HeaderTextStyle}"/>
                <TextBlock x:Name="CommittedMemoryText" Style="{StaticResource DataTextStyle}"/>
                <TextBlock x:Name="PhysicalMemoryText" Style="{StaticResource DataTextStyle}"/>
                <TextBlock x:Name="LastUpdateText"
                           Style="{StaticResource DataTextStyle}"
                           Foreground="Gray"
                           FontSize="11"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- 操作按钮栏 -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button x:Name="RefreshButton"
                    Content="🔄 刷新"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="RefreshButton_Click"/>
            <Button x:Name="ReleaseButton"
                    Content="💾 释放工作集"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="ReleaseButton_Click"
                    IsEnabled="False"
                    ToolTip="释放物理内存（不减少已提交内存）"/>
            <Button x:Name="TerminateButton"
                    Content="⚠️ 终止进程"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="TerminateButton_Click"
                    IsEnabled="False"
                    Background="#FFE57373"
                    ToolTip="终止进程（真正释放已提交内存，会丢失数据）"/>
            <Button x:Name="ExperimentalReleaseButton"
                    Content="🧪 实验性释放"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="ExperimentalReleaseButton_Click"
                    IsEnabled="False"
                    Background="#FFFFB74D"
                    ToolTip="实验性 VirtualFreeEx（极度危险，50%+崩溃风险）"/>
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"
                       FontSize="12"
                       Foreground="Green"/>
        </StackPanel>

        <!-- 进程列表 -->
        <Border Grid.Row="2"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="5">
            <DataGrid x:Name="ProcessDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="ProcessDataGrid_SelectionChanged"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F5F5F5"
                      RowHeight="32"
                      FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PID"
                                        Binding="{Binding ProcessId}"
                                        Width="80"/>
                    <DataGridTextColumn Header="进程名称"
                                        Binding="{Binding ProcessName}"
                                        Width="150"/>
                    <DataGridTextColumn Header="类型"
                                        Binding="{Binding ProcessType}"
                                        Width="100"/>
                    <DataGridTextColumn Header="已提交内存"
                                        Binding="{Binding FormattedPrivate}"
                                        Width="120"/>
                    <DataGridTextColumn Header="工作集（物理内存）"
                                        Binding="{Binding FormattedWorkingSet}"
                                        Width="140"/>
                    <DataGridTextColumn Header="状态"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="正常"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                        <Setter Property="Text" Value="🔒 受保护"/>
                                        <Setter Property="Foreground" Value="Red"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SuggestClose}" Value="True">
                                        <Setter Property="Text" Value="💡 建议关闭"/>
                                        <Setter Property="Foreground" Value="Orange"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>



