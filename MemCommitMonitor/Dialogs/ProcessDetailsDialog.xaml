<Window x:Class="MemCommitMonitor.Dialogs.ProcessDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="600"
        Height="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="White"
            CornerRadius="12"
            Padding="32">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.2"
                            BlurRadius="24" ShadowDepth="8" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="TitleText"
                          FontSize="20"
                          FontWeight="SemiBold"
                          Margin="0,0,0,8"/>
                <Rectangle Height="1"
                          Fill="#FFE5E5EA"
                          Margin="0,8,0,0"/>
            </StackPanel>

            <!-- 详情内容 -->
            <ScrollViewer Grid.Row="1"
                         VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ContentPanel">
                    <!-- 内容将通过代码添加 -->
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Button Grid.Row="2"
                    Content="关闭"
                    HorizontalAlignment="Right"
                    MinWidth="100"
                    Height="36"
                    Margin="0,20,0,0"
                    FontSize="13"
                    FontWeight="Medium"
                    Background="#FF007AFF"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CloseButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
