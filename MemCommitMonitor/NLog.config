<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

  <!-- 定义日志变量 -->
  <variable name="appName" value="MemCommitMonitor"/>
  <variable name="logDirectory" value="${specialfolder:folder=ApplicationData}/${appName}/Logs"/>

  <!-- 定义日志输出目标 -->
  <targets>

    <!-- 文件日志 - 所有级别 -->
    <target xsi:type="File"
            name="allfile"
            fileName="${logDirectory}/${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
            archiveFileName="${logDirectory}/archives/${shortdate}.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- 文件日志 - 只记录错误 -->
    <target xsi:type="File"
            name="errorfile"
            fileName="${logDirectory}/errors-${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}${newline}${exception:format=tostring}${newline}---"
            archiveFileName="${logDirectory}/archives/errors-${shortdate}.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="90"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- 控制台日志 - 调试时使用 -->
    <target xsi:type="Console"
            name="console"
            layout="${time}|${level:uppercase=true}|${logger:shortName=true}|${message}" />

    <!-- 调试输出 - Visual Studio 输出窗口 -->
    <target xsi:type="Debugger"
            name="debugger"
            layout="${time}|${level:uppercase=true}|${logger:shortName=true}|${message}" />

  </targets>

  <!-- 定义日志规则 -->
  <rules>
    <!-- 所有日志写入文件 -->
    <logger name="*" minlevel="Debug" writeTo="allfile" />

    <!-- 错误和致命错误单独记录 -->
    <logger name="*" minlevel="Error" writeTo="errorfile" />

    <!-- Debug 模式下输出到控制台 -->
    <logger name="*" minlevel="Info" writeTo="console" />

    <!-- Debug 模式下输出到 VS 调试窗口 -->
    <logger name="*" minlevel="Debug" writeTo="debugger" />
  </rules>

</nlog>
