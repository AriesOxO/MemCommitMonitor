<Window x:Class="MemCommitMonitor.LogoPreview"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logo Preview"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Window.Resources>
        <ResourceDictionary Source="Resources/Logo.xaml"/>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="MemCommit Monitor Logo"
                   FontSize="32"
                   FontWeight="SemiBold"
                   Margin="0,0,0,40"
                   HorizontalAlignment="Center"/>

        <!-- Logo 展示 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- 大 Logo -->
            <Border Background="#FFF5F5F7" Padding="40" CornerRadius="20" Margin="0,0,0,40">
                <StackPanel>
                    <TextBlock Text="主要 Logo (256x256)"
                              FontSize="14"
                              Foreground="Gray"
                              Margin="0,0,0,20"
                              HorizontalAlignment="Center"/>
                    <Image Source="{StaticResource AppLogo}"
                           Width="256" Height="256"/>
                </StackPanel>
            </Border>

            <!-- 小尺寸展示 -->
            <Border Background="#FFF5F5F7" Padding="40" CornerRadius="20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <!-- 64x64 -->
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="64x64"
                                  FontSize="12"
                                  Foreground="Gray"
                                  Margin="0,0,0,10"
                                  HorizontalAlignment="Center"/>
                        <Image Source="{StaticResource AppLogoSmall}"
                               Width="64" Height="64"/>
                    </StackPanel>

                    <!-- 32x32 -->
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="32x32"
                                  FontSize="12"
                                  Foreground="Gray"
                                  Margin="0,0,0,10"
                                  HorizontalAlignment="Center"/>
                        <Image Source="{StaticResource AppLogoSmall}"
                               Width="32" Height="32"/>
                    </StackPanel>

                    <!-- 16x16 -->
                    <StackPanel>
                        <TextBlock Text="16x16"
                                  FontSize="12"
                                  Foreground="Gray"
                                  Margin="0,0,0,10"
                                  HorizontalAlignment="Center"/>
                        <Image Source="{StaticResource AppLogoSmall}"
                               Width="16" Height="16"/>
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Window>
