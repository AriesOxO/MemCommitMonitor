<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- MemCommitMonitor Logo - macOS Style -->
    <DrawingImage x:Key="AppLogo">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- 圆角背景 - 蓝色渐变 -->
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,256,256" RadiusX="48" RadiusY="48"/>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF007AFF" Offset="0"/>
                            <GradientStop Color="#FF0051D5" Offset="1"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>

                <!-- 字母 M - 白色 -->
                <GeometryDrawing Brush="White">
                    <GeometryDrawing.Geometry>
                        <!-- M 字母路径 -->
                        <PathGeometry>
                            <PathFigure StartPoint="60,180">
                                <LineSegment Point="60,80"/>
                                <LineSegment Point="128,140"/>
                                <LineSegment Point="196,80"/>
                                <LineSegment Point="196,180"/>
                                <LineSegment Point="170,180"/>
                                <LineSegment Point="170,120"/>
                                <LineSegment Point="128,165"/>
                                <LineSegment Point="86,120"/>
                                <LineSegment Point="86,180"/>
                                <LineSegment Point="60,180"/>
                            </PathFigure>
                        </PathGeometry>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- 内存条图案 - 底部装饰 -->
                <GeometryDrawing Brush="#80FFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="70,190,30,20" RadiusX="2" RadiusY="2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#60FFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="110,190,30,20" RadiusX="2" RadiusY="2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#FFFFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="150,190,30,20" RadiusX="2" RadiusY="2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 小尺寸 Logo (16x16/32x32) -->
    <DrawingImage x:Key="AppLogoSmall">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- 简化版 - 只有背景和 M -->
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,64,64" RadiusX="12" RadiusY="12"/>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF007AFF" Offset="0"/>
                            <GradientStop Color="#FF0051D5" Offset="1"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>

                <!-- 简化的 M -->
                <GeometryDrawing Brush="White">
                    <GeometryDrawing.Geometry>
                        <PathGeometry>
                            <PathFigure StartPoint="15,48">
                                <LineSegment Point="15,20"/>
                                <LineSegment Point="32,36"/>
                                <LineSegment Point="49,20"/>
                                <LineSegment Point="49,48"/>
                                <LineSegment Point="43,48"/>
                                <LineSegment Point="43,30"/>
                                <LineSegment Point="32,41"/>
                                <LineSegment Point="21,30"/>
                                <LineSegment Point="21,48"/>
                                <LineSegment Point="15,48"/>
                            </PathFigure>
                        </PathGeometry>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
